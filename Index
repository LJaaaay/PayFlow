  { name: "XPD GLOBAL USA",       amount: 1195.0,  count: 1 },
  { name: "NEXUS TRADE CO LLC",   amount: 915.0,   count: 1 },
  { name: "Super Cargo GS USA",   amount: 790.0,   count: 1 },
  { name: "EP AMERICA INC.",      amount: 750.0,   count: 1 },
  { name: "INTL TRINITY CUSTOMS", amount: 630.0,   count: 8 },
  { name: "JRF DELIVERY INC",     amount: 570.0,   count: 5 },
